        {
          "name": "Create Subscription",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\",()=>pm.response.to.have.status(201));",
                  "pm.test(\"Subscription is active or trialing\",()=>{",
                  "  pm.expect([\"active\",\"trialing\"]).to.include(pm.response.json().status);});",
                  "pm.test(\"Has period dates\",()=>{const b=pm.response.json();",
                  "  pm.expect(b.currentPeriodStart).to.be.a(\"string\");",
                  "  pm.expect(b.currentPeriodEnd).to.be.a(\"string\");",
                  "  pm.environment.set(\"subscriptionId\",b.id);});"
                ],
                "type": "text/javascript"
              }
            }
