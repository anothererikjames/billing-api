      "name": "Subscriptions",
      "item": [
        {
          "name": "List Subscriptions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\",()=>pm.response.to.have.status(200));",
                  "pm.test(\"Returns data array\",()=>pm.expect(pm.response.json().data).to.be.an(\"array\"));",
                  "pm.test(\"Response time < 600ms\",()=>pm.expect(pm.response.responseTime).to.be.below(600));",
                  "const d=pm.response.json().data;if(d&&d.length>0)pm.environment.set(\"subscriptionId\",d[0].id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/subscriptions?status=active&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "subscriptions"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "active"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "header": [],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}"
                }
              ]
            }
